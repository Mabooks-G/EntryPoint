# EntryPoint Backend — Environment Variables
# Copy this to .env and fill in your values

SUPABASE_URL=https://yuzcgqgojznjrimggfbo.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Gemma 4 via Fireworks AI (OpenAI-compatible API) — get key from https://app.fireworks.ai/account/api-keys
# Fireworks AI credits are available through the AMD AI Developer Program
FIREWORKS_API_KEY=fw_your_key_here

# Gemma 4 model on Fireworks AI
FIREWORKS_MODEL=accounts/fireworks/models/gemma-4-26b-a4b-it

HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,https://*.nativelyai.app